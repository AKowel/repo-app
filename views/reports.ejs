<%- include('partials/head', { pageTitle: 'Reports' }) %>
<div class="app-shell">
<%- include('partials/header', { activePage: 'reports' }) %>
<div class="main">
<%- include('partials/topbar', { pageLabel: 'Reports' }) %>
<div class="pc">

  <div class="phead">
    <div class="ph">
      <div>
        <span class="pt">Pick Analysis</span>
        <span class="ps">Warehouse picking reports · all channels</span>
      </div>
      <div class="ph-chips">
        <span class="chip" id="rChipClient"></span>
        <span class="chip" id="rChipRange"></span>
        <span class="chip" id="rChipCoverage"></span>
        <span class="chip chip--a" id="rChipQty"></span>
        <span class="chip" id="rChipLines"></span>
        <span class="chip chip--status" id="rChipStatus"></span>
      </div>
    </div>
  </div>

  <!-- Toolbar (padded, not full-bleed) -->
  <div class="padded" style="padding-bottom:0">
    <div class="card" style="margin-bottom:0;border-bottom:none;border-radius:var(--radius-lg) var(--radius-lg) 0 0">
      <div class="tb" style="border-bottom:none">
        <div class="fg">
          <div class="fl">Client</div>
          <select class="fi" id="rSelClient">
            <% clientChoices.forEach(c => { %>
              <option value="<%= c.code %>" <%= c.code === selectedClient ? 'selected' : '' %>><%= c.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="fg">
          <div class="fl">Report window</div>
          <select class="fi" id="rSelMode" style="width:170px">
            <option value="latest">Latest complete day</option>
            <option value="last_week">Last week</option>
            <option value="last_2_weeks">Last 2 weeks</option>
            <option value="last_month">Last month</option>
            <option value="last_3_months">Last 3 months</option>
            <option value="last_6_months">Last 6 months</option>
            <option value="last_12_months">Last 12 months</option>
            <option value="date">Specific date</option>
            <option value="custom">Custom range</option>
          </select>
        </div>
        <div class="fg" id="rGrpDate" style="display:none">
          <div class="fl">Date</div>
          <input class="fi" type="date" id="rInpDate" />
        </div>
        <div class="fg" id="rGrpRange" style="display:none">
          <div class="fl">From</div>
          <input class="fi" type="date" id="rInpStart" />
        </div>
        <div class="fg" id="rGrpRangeEnd" style="display:none">
          <div class="fl">To</div>
          <input class="fi" type="date" id="rInpEnd" />
        </div>
        <div class="fg">
          <div class="fl">Channels</div>
          <div class="reports-channel-picker" id="rChannelPicker">
            <button type="button" class="fi reports-channel-picker__trigger" id="rChannelTrigger">All channels</button>
            <div class="reports-channel-picker__dropdown" id="rChannelDropdown" hidden></div>
          </div>
        </div>
        <div class="fg">
          <div class="fl">Top SKUs</div>
          <select class="fi" id="rSelLimit" style="width:70px">
            <option value="10">10</option>
            <option value="25" selected>25</option>
            <option value="50">50</option>
            <option value="100">100</option>
          </select>
        </div>
        <div class="fg">
          <div class="fl">Rank by</div>
          <select class="fi" id="rSelRankBy" style="width:110px">
            <option value="pick_qty">Pick qty</option>
            <option value="line_count">Line count</option>
          </select>
        </div>
        <div class="fg" style="align-self:flex-end;padding-bottom:3px">
          <label style="display:flex;align-items:center;gap:6px;cursor:pointer;white-space:nowrap;font-family:var(--mono);font-size:10px;color:var(--text-soft)">
            <input type="checkbox" id="rHideGrp147" style="accent-color:var(--accent);width:12px;height:12px;cursor:pointer" />
            Hide group 147
          </label>
        </div>
        <button class="btn btn--primary btn--sm" id="rBtnLoad" style="align-self:flex-end">Reload</button>
        <button class="btn btn--sm" id="rBtnExport" style="align-self:flex-end;display:inline-flex;align-items:center;gap:5px" title="Export all data to Excel">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Export .xlsx
        </button>
      </div>
    </div>
  </div>

  <!-- Full-bleed tabs + content -->
  <div class="card-edge reports-results-card" style="margin:0 24px;border-radius:0 0 var(--radius-lg) var(--radius-lg);border-left:1px solid var(--border);border-right:1px solid var(--border);border-bottom:1px solid var(--border)">
    <div class="tabrow" id="rTabs">
      <button class="tabbtn reports-tab-btn reports-tab-btn--active tabbtn--on" data-tab="overview">Overview</button>
      <button class="tabbtn reports-tab-btn" data-tab="skus">Top SKUs</button>
      <button class="tabbtn reports-tab-btn" data-tab="locations">Locations</button>
      <button class="tabbtn reports-tab-btn" data-tab="aisles">Aisles</button>
      <button class="tabbtn reports-tab-btn" data-tab="structure">Structure</button>
      <button class="tabbtn reports-tab-btn" data-tab="channels">Channels</button>
      <button class="tabbtn reports-tab-btn" data-tab="replenishment">Replenishment</button>
      <button class="tabbtn reports-tab-btn" data-tab="pc-zone">PC Zone</button>
      <button class="tabbtn reports-tab-btn" data-tab="daily">Daily</button>
    </div>
    <div style="flex:1;overflow-y:auto">
      <div id="rTab-overview"      class="reports-tab-content reports-tab-content--active"></div>
      <div id="rTab-skus"          class="reports-tab-content"></div>
      <div id="rTab-locations"     class="reports-tab-content"></div>
      <div id="rTab-aisles"        class="reports-tab-content"></div>
      <div id="rTab-structure"     class="reports-tab-content"></div>
      <div id="rTab-channels"      class="reports-tab-content"></div>
      <div id="rTab-replenishment" class="reports-tab-content"></div>
      <div id="rTab-pc-zone"       class="reports-tab-content"></div>
      <div id="rTab-daily"         class="reports-tab-content"></div>
    </div>
  </div>

</div>
</div>
</div>

<!-- Export modal -->
<div class="rmodal-backdrop" id="rExportModalBackdrop" hidden>
  <div class="rmodal" role="dialog" aria-modal="true" aria-labelledby="rExportModalTitle">
    <div class="rmodal__head">
      <div class="rmodal__title" id="rExportModalTitle">Export to Excel</div>
      <button class="rmodal__close" id="rExportModalClose" aria-label="Close">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="rmodal__body" id="rExportModalBody"></div>
    <div class="rmodal__foot">
      <button class="btn btn--sm" id="rExportModalCancel">Cancel</button>
      <button class="btn btn--primary btn--sm" id="rExportModalConfirm" style="display:inline-flex;align-items:center;gap:5px">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download .xlsx
      </button>
    </div>
  </div>
</div>

<!-- Detail drawer -->
<div class="drawer-backdrop" id="rDetailDrawerBackdrop"></div>
<div class="drawer" id="rDetailDrawer" role="dialog" aria-modal="true" aria-labelledby="rDetailDrawerTitle">
  <div class="drawer__head">
    <div>
      <div class="drawer__title" id="rDetailDrawerTitle">Report Detail</div>
      <div class="drawer__subtitle" id="rDetailDrawerSubtitle"></div>
    </div>
    <button class="drawer__close" id="rDetailDrawerClose" aria-label="Close">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>
  <div class="drawer__body" id="rDetailDrawerBody">
    <div class="loading-row"><div class="spinner"></div> Loading detail…</div>
  </div>
</div>

<script src="/js/site.js?v=<%= assetVersion %>"></script>
<link rel="stylesheet" href="/css/reports.css?v=<%= assetVersion %>" />
<script src="https://unpkg.com/xlsx/dist/xlsx.full.min.js"></script>
<script src="/js/reports.js?v=<%= assetVersion %>"></script>
</body>
</html>
