<%- include('partials/head', { pageTitle: 'Error ' + (error.status || 500) }) %>
<div class="app-shell">
<% if (currentUser) { %>
<%- include('partials/header') %>
<div class="main">
<%- include('partials/topbar', { pageLabel: 'Error' }) %>
<div class="pc"><div class="pc-scroll"><div class="padded">
<% } else { %>
<div class="main" style="width:100%">
<div class="pc"><div class="pc-scroll"><div class="padded">
<% } %>

  <div style="max-width:560px;margin:60px auto">
    <div class="card">
      <div class="card__body" style="text-align:center;padding:48px 32px">
        <div style="font-family:var(--mono);font-size:3rem;font-weight:700;color:var(--text-xsoft);margin-bottom:16px;letter-spacing:-0.04em">
          <%= error.status || 500 %>
        </div>
        <h1 style="font-size:18px;font-weight:700;margin-bottom:8px;color:var(--text)">Something went wrong</h1>
        <p style="color:var(--text-soft);margin-bottom:28px;font-size:13px"><%= error.message || 'An unexpected error occurred.' %></p>
        <% if (currentUser) { %>
          <a href="/heatmap" class="btn btn--primary">← Back to Heatmap</a>
        <% } else { %>
          <a href="/login" class="btn btn--primary">← Back to Login</a>
        <% } %>
      </div>
    </div>
  </div>

</div></div></div>
</div>
</div>

<%- include('partials/footer') %>
