<%- include('partials/head', { pageTitle: 'Heatmap' }) %>
<div class="app-shell">
<%- include('partials/header', { activePage: 'heatmap' }) %>
<main class="app-main">
<div class="page">

  <div class="page-hero">
    <div class="page-hero__eyebrow">Pick Activity</div>
    <h1 class="page-hero__title">Warehouse Heatmap</h1>
    <div class="page-hero__chips">
      <span class="chip" id="heatmapDateChip">Loading snapshots...</span>
      <span class="chip" id="heatmapSnapshotStatusChip">Checking...</span>
      <span class="chip" id="heatmapLocationChip">0 locations</span>
      <span class="chip" id="heatmapPickChip">0 picks</span>
    </div>
  </div>

  <section class="heatmap-fullscreen-shell" id="heatmapLayout">

    <!-- Toolbar -->
    <div class="card heatmap-toolbar-card">
      <div class="card__head">
        <div class="card__title">Scene Controls</div>
        <span class="chip" id="heatmapStatusChip">Loading...</span>
      </div>
      <div class="card__body heatmap-toolbar-body">
        <div class="field-group">
          <label class="field-label">Client</label>
          <select class="field field--select" id="heatmapClientSelect" style="width:180px">
            <% clientChoices.forEach(c => { %>
              <option value="<%= c.code %>" <%= c.code === selectedClient ? 'selected' : '' %>><%= c.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="field-group">
          <label class="field-label">View mode</label>
          <select class="field field--select" id="heatmapModeSelect" style="width:180px">
            <option value="latest">Latest complete day</option>
            <option value="date">Specific date</option>
          </select>
        </div>
        <div class="field-group" id="heatmapDateField" hidden>
          <label class="field-label">Snapshot date</label>
          <select class="field field--select" id="heatmapDateSelect" style="width:150px">
            <option value="">No snapshots yet</option>
          </select>
        </div>
        <div class="field-group">
          <label class="field-label">Heat metric</label>
          <select class="field field--select" id="heatmapMetricSelect" style="width:150px">
            <option value="pick_count">Pick count</option>
            <option value="pick_qty">Pick quantity</option>
          </select>
        </div>
        <div class="field-group">
          <label class="field-label">Camera</label>
          <select class="field field--select" id="heatmapCameraModeSelect" style="width:140px">
            <option value="orbit">Perspective</option>
            <option value="top">Top-down</option>
            <option value="fps">FPS</option>
          </select>
        </div>
        <div class="field-group">
          <label class="field-label">Colour mode</label>
          <select class="field field--select" id="heatmapColourModeSelect" style="width:140px">
            <option value="heatmap">Heatmap</option>
            <option value="binsize">Bin size</option>
            <option value="zone">Zone</option>
            <option value="level">Level</option>
          </select>
        </div>
        <div class="field-group heatmap-level-filter-field">
          <label class="field-label">Visible levels</label>
          <div class="heatmap-level-filter">
            <input class="field" type="number" id="heatmapLevelMin" min="0" max="99" placeholder="Min" style="width:68px">
            <span style="color:var(--text-soft);font-size:0.85rem">–</span>
            <input class="field" type="number" id="heatmapLevelMax" min="0" max="99" placeholder="Max" style="width:68px">
            <button class="btn btn--ghost btn--sm" id="heatmapLevelResetButton">All</button>
          </div>
        </div>
        <div class="field-group">
          <label class="field-label">Find location</label>
          <input class="field" type="search" id="heatmapSearchInput" placeholder="e.g. WF44" style="width:180px">
        </div>
        <label class="heatmap-toggle">
          <input type="checkbox" id="heatmapPickedOnly"> Only picked
        </label>
        <label class="heatmap-toggle">
          <input type="checkbox" id="heatmapOccupiedOnly"> Only occupied
        </label>
        <div class="heatmap-toolbar-actions">
          <button class="btn btn--ghost btn--sm" id="heatmapResetCameraButton">Reset camera</button>
          <button class="btn btn--primary btn--sm" id="heatmapReloadButton">Reload</button>
        </div>
      </div>
    </div>

    <!-- Scene + sidebar -->
    <div class="heatmap-layout-grid">

      <!-- 3D scene -->
      <div class="card heatmap-scene-card">
        <div class="card__head">
          <div class="card__title">3D Warehouse Rack View</div>
          <div style="display:flex;gap:8px;align-items:center">
            <button class="btn btn--ghost btn--sm" id="heatmapSettingsButton">&#9881; Settings</button>
            <button class="btn btn--ghost btn--sm" id="heatmapFullscreenButton">Full screen</button>
          </div>
        </div>
        <div class="heatmap-scene-wrap">
          <canvas id="heatmapCanvas"></canvas>

          <div class="heatmap-settings-panel" id="heatmapSettingsPanel" hidden>
            <div class="heatmap-settings-panel__head">
              <strong>Scene Settings</strong>
              <button class="heatmap-settings-close" id="heatmapSettingsClose">&#10005;</button>
            </div>
            <label class="heatmap-settings-row">
              <span>Orbit speed</span>
              <input type="range" id="rotateSpeedInput" min="0.1" max="4" step="0.1" value="1">
              <span id="rotateSpeedLabel" class="heatmap-settings-val">1.0</span>
            </label>
            <label class="heatmap-settings-row">
              <span>Zoom speed</span>
              <input type="range" id="zoomSpeedInput" min="0.1" max="6" step="0.1" value="1">
              <span id="zoomSpeedLabel" class="heatmap-settings-val">1.0</span>
            </label>
            <label class="heatmap-settings-row">
              <span>Pan speed</span>
              <input type="range" id="panSpeedInput" min="0.1" max="4" step="0.1" value="1">
              <span id="panSpeedLabel" class="heatmap-settings-val">1.0</span>
            </label>
            <label class="heatmap-settings-row">
              <span>WASD speed</span>
              <input type="range" id="wasdSpeedInput" min="0.3" max="6" step="0.1" value="1">
              <span id="wasdSpeedLabel" class="heatmap-settings-val">1.0&#215;</span>
            </label>
            <button class="heatmap-settings-reset" id="heatmapSettingsReset">Reset defaults</button>
          </div>

          <div class="heatmap-scene-hint" id="heatmapSceneHint">
            <strong>Full screen controls</strong>
            <span><code>W A S D</code> move &middot; drag orbits &middot; scroll zooms &middot; <code>Esc</code> exits</span>
          </div>

          <div class="heatmap-fps-overlay" id="heatmapFpsOverlay" hidden>
            <div class="heatmap-fps-crosshair"></div>
            <div class="heatmap-fps-chip" id="heatmapFpsModeChip">FPS Look Mode</div>
            <div class="heatmap-fps-help">W A S D move &middot; E / C up-down &middot; mouse look &middot; Tab edit &middot; Esc unlock</div>
          </div>

          <div class="heatmap-legend">
            <div class="heatmap-legend__bar"></div>
            <div class="heatmap-legend__labels">
              <span>Cool</span>
              <span>Warm</span>
              <span>Hot</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="card heatmap-sidebar">
        <div class="card__head"><div class="card__title">Location Detail</div></div>
        <div class="card__body" style="display:grid;gap:16px">

          <p id="heatmapDetailHint" style="color:var(--text-soft);font-size:0.875rem;margin:0">Click a rack cube in the scene to inspect it.</p>

          <div class="heatmap-stats-grid">
            <div class="heatmap-stat-card">
              <div class="heatmap-stat-card__label">Occupied</div>
              <div class="heatmap-stat-card__value" id="heatmapOccupiedMetric">0</div>
              <div class="heatmap-stat-card__sub">locations with a live SKU</div>
            </div>
            <div class="heatmap-stat-card">
              <div class="heatmap-stat-card__label">Picked</div>
              <div class="heatmap-stat-card__value" id="heatmapPickedMetric">0</div>
              <div class="heatmap-stat-card__sub">active in selected view</div>
            </div>
          </div>

          <div id="heatmapSnapshotInfo" class="heatmap-snapshot-info">
            <strong>Checking snapshot availability...</strong>
          </div>

          <div id="heatmapDetailCard" class="heatmap-detail-card">
            <strong class="heatmap-detail-card__empty">No location selected yet.</strong>
          </div>

          <div>
            <div class="card__subtitle" style="margin-bottom:10px">Hottest aisles</div>
            <div id="heatmapHotAisles"></div>
          </div>

        </div>
      </aside>
    </div>

  </section>

</div>
</main>
</div>

<script src="/js/site.js"></script>
<script type="importmap">
{
  "imports": {
    "three": "/vendor/three/build/three.module.js",
    "three/addons/": "/vendor/three/examples/jsm/"
  }
}
</script>
<script type="module" src="/js/heatmap.js"></script>
</body>
</html>
