<%- include('partials/head', { pageTitle: 'Admin' }) %>
<div class="app-shell">
<%- include('partials/header', { activePage: 'admin' }) %>
<div class="main">
<%- include('partials/topbar', { pageLabel: 'Admin' }) %>
<div class="pc">
<div class="pc-scroll">
<div class="padded">

  <div class="phead" style="padding-left:0;padding-right:0">
    <div class="ph">
      <div>
        <span class="pt">Admin Panel</span>
        <span class="ps">System status and diagnostics</span>
      </div>
      <div class="ph-chips">
        <span class="chip" id="chipUptime">—</span>
        <span class="chip" id="chipPb">—</span>
        <span class="chip" id="chipNode">—</span>
      </div>
    </div>
  </div>

  <!-- Status row -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px">

    <div class="card">
      <div class="card__head">
        <div class="card__title">PocketBase Connection</div>
        <button class="btn btn--g btn--sm" onclick="loadStatus()">Refresh</button>
      </div>
      <div class="card__body" id="pbStatus">
        <div class="loading-row"><div class="spinner"></div></div>
      </div>
    </div>

    <div class="card">
      <div class="card__head"><div class="card__title">Server Info</div></div>
      <div class="card__body" id="serverInfo">
        <div class="loading-row"><div class="spinner"></div></div>
      </div>
    </div>

  </div>

  <!-- Snapshot summary -->
  <div class="card" style="margin-bottom:10px">
    <div class="card__head">
      <div class="card__title">Snapshot Summary</div>
      <button class="btn btn--g btn--sm" onclick="loadSnapshotSummary()">Refresh</button>
    </div>
    <div class="card__body--flush" id="snapshotSummary">
      <div class="loading-row"><div class="spinner"></div></div>
    </div>
  </div>

  <!-- Active bin sizes -->
  <div class="card" style="margin-bottom:10px">
    <div class="card__head">
      <div class="card__title">Active Bin Sizes</div>
      <div style="display:flex;align-items:center;gap:8px">
        <select class="fi" id="binSizeClient" style="width:150px" onchange="loadBinSizes()">
          <% clientChoices.forEach(c => { %>
            <option value="<%= c.code %>"><%= c.name %></option>
          <% }) %>
        </select>
        <button class="btn btn--g btn--sm" onclick="loadBinSizes()">Refresh</button>
      </div>
    </div>
    <div class="card__body--flush" id="binSizeTable">
      <div class="loading-row"><div class="spinner"></div></div>
    </div>
  </div>

  <!-- Cache contents -->
  <div class="card" style="margin-bottom:10px">
    <div class="card__head">
      <div class="card__title">In-Memory Cache</div>
      <button class="btn btn--g btn--sm" onclick="loadStatus()">Refresh</button>
    </div>
    <div class="card__body--flush" id="cacheTable">
      <div class="loading-row"><div class="spinner"></div></div>
    </div>
  </div>

  <!-- Snapshot debugger -->
  <div class="card">
    <div class="card__head">
      <div class="card__title">Snapshot Debugger</div>
      <span style="font-family:var(--mono);font-size:9px;color:var(--text-soft)">Inspect what a snapshot file actually contains</span>
    </div>
    <div class="card__body">
      <div style="display:flex;flex-wrap:wrap;gap:10px;align-items:flex-end;margin-bottom:16px">
        <div class="fg">
          <div class="fl">Collection</div>
          <select class="fi" id="dbgCollection" style="width:190px">
            <option value="pick_activity">Pick Activity</option>
            <option value="order_lines">Order Lines</option>
            <option value="pick_transactions">Pick Transactions</option>
            <option value="binloc">BINLOC</option>
          </select>
        </div>
        <div class="fg">
          <div class="fl">Client</div>
          <select class="fi" id="dbgClient" style="width:150px">
            <% clientChoices.forEach(c => { %>
              <option value="<%= c.code %>"><%= c.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="fg">
          <div class="fl">Date (blank = latest)</div>
          <input class="fi" type="date" id="dbgDate" style="width:160px" />
        </div>
        <button class="btn btn--primary" onclick="runDebug()">Inspect</button>
      </div>
      <div id="dbgResult"></div>
    </div>
  </div>

</div>
</div>
</div>
</div>
</div>

<script src="/js/site.js"></script>
<script src="/js/admin.js"></script>
</body>
</html>
