<div class="tbar">
  <div class="tbar__bc">
    <span>report-app</span>
    <span class="tbar__bc-sep">/</span>
    <b><%= typeof pageLabel !== 'undefined' ? pageLabel : '' %></b>
  </div>
  <div class="tbar__r">
    <span class="tbar-lbl">theme</span>
    <div class="tdot" data-theme-target="carbon"   style="background:#4f8ef7" title="Carbon"></div>
    <div class="tdot" data-theme-target="terminal" style="background:#34d058" title="Terminal"></div>
    <div class="tdot" data-theme-target="ember"    style="background:#f0a030" title="Ember"></div>
    <div class="tbar-sep"></div>
    <div class="tdot" data-theme-target="light"    style="background:#2563eb" title="Light"></div>
    <div class="tdot" data-theme-target="frost"    style="background:#6366f1" title="Frost"></div>
    <div class="tdot" data-theme-target="warm"     style="background:#c2770a" title="Warm"></div>
    <div class="tbar-sep"></div>
    <button class="tbar-settings-btn" id="settingsBtn" title="Settings">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3"/>
        <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
      </svg>
    </button>
    <% if (typeof currentUser !== 'undefined' && currentUser) { %>
    <div style="width:1px;height:14px;background:var(--sb-border);margin:0 4px;flex-shrink:0"></div>
    <div style="width:26px;height:26px;border-radius:50%;background:rgba(255,255,255,0.06);border:1px solid var(--accent);display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:10px;font-weight:700;color:var(--accent)">
      <%= (currentUser.name || currentUser.email || '?').charAt(0).toUpperCase() %>
    </div>
    <% } %>
  </div>
</div>

<!-- Settings Modal -->
<div class="rmodal-backdrop" id="settingsBackdrop" hidden>
  <div class="rmodal settings-modal">
    <div class="rmodal__head">
      <span class="rmodal__title">Settings</span>
      <button class="rmodal__close" id="settingsClose" aria-label="Close settings">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="rmodal__body">

      <!-- Nav Layout -->
      <div class="settings-section">
        <div class="settings-section__label">Navigation Layout</div>
        <div class="settings-section__hint">Choose how the navigation is displayed across all pages</div>
        <div class="settings-layout-grid">

          <button class="settings-layout-btn" data-setting="nav-layout" data-value="sidebar">
            <svg class="settings-layout-preview" viewBox="0 0 60 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="0.5" y="0.5" width="59" height="39" rx="3" stroke="currentColor" stroke-opacity="0.25"/>
              <rect x="1" y="1" width="14" height="38" rx="2" fill="currentColor" fill-opacity="0.18"/>
              <rect x="19" y="8"  width="34" height="2.5" rx="1" fill="currentColor" fill-opacity="0.28"/>
              <rect x="19" y="15" width="26" height="2.5" rx="1" fill="currentColor" fill-opacity="0.15"/>
              <rect x="19" y="22" width="30" height="2.5" rx="1" fill="currentColor" fill-opacity="0.15"/>
              <rect x="19" y="29" width="20" height="2.5" rx="1" fill="currentColor" fill-opacity="0.15"/>
            </svg>
            <span>Sidebar</span>
          </button>

          <button class="settings-layout-btn" data-setting="nav-layout" data-value="bottom">
            <svg class="settings-layout-preview" viewBox="0 0 60 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="0.5" y="0.5" width="59" height="39" rx="3" stroke="currentColor" stroke-opacity="0.25"/>
              <rect x="5"  y="7"  width="50" height="2.5" rx="1" fill="currentColor" fill-opacity="0.28"/>
              <rect x="5"  y="14" width="36" height="2.5" rx="1" fill="currentColor" fill-opacity="0.15"/>
              <rect x="5"  y="21" width="42" height="2.5" rx="1" fill="currentColor" fill-opacity="0.15"/>
              <rect x="1"  y="30" width="58" height="9"   rx="2" fill="currentColor" fill-opacity="0.18"/>
            </svg>
            <span>Bottom Bar</span>
          </button>

        </div>
      </div>

      <!-- Empty Bin Layout -->
      <div class="settings-section">
        <div class="settings-section__label">Empty Bin Layout</div>
        <div class="settings-section__hint">Choose how the empty bin page panels are arranged</div>
        <div class="settings-layout-grid">

          <button class="settings-layout-btn" data-setting="empty-bin-layout" data-value="side-by-side">
            <svg class="settings-layout-preview" viewBox="0 0 60 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="0.5"  y="0.5" width="22" height="39" rx="2.5" stroke="currentColor" stroke-opacity="0.25" fill="currentColor" fill-opacity="0.1"/>
              <rect x="25.5" y="0.5" width="34" height="39" rx="2.5" stroke="currentColor" stroke-opacity="0.25" fill="currentColor" fill-opacity="0.06"/>
              <rect x="3"  y="6"  width="16" height="2" rx="1" fill="currentColor" fill-opacity="0.3"/>
              <rect x="3"  y="11" width="13" height="2" rx="1" fill="currentColor" fill-opacity="0.18"/>
              <rect x="3"  y="16" width="15" height="2" rx="1" fill="currentColor" fill-opacity="0.18"/>
              <rect x="3"  y="21" width="12" height="2" rx="1" fill="currentColor" fill-opacity="0.18"/>
              <rect x="28" y="6"  width="28" height="2" rx="1" fill="currentColor" fill-opacity="0.3"/>
              <rect x="28" y="13" width="22" height="2" rx="1" fill="currentColor" fill-opacity="0.18"/>
              <rect x="28" y="20" width="26" height="2" rx="1" fill="currentColor" fill-opacity="0.18"/>
              <rect x="28" y="27" width="18" height="2" rx="1" fill="currentColor" fill-opacity="0.18"/>
            </svg>
            <span>Side by Side</span>
          </button>

          <button class="settings-layout-btn" data-setting="empty-bin-layout" data-value="stacked">
            <svg class="settings-layout-preview" viewBox="0 0 60 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="0.5" y="0.5"  width="59" height="17" rx="2.5" stroke="currentColor" stroke-opacity="0.25" fill="currentColor" fill-opacity="0.1"/>
              <rect x="0.5" y="21.5" width="59" height="18" rx="2.5" stroke="currentColor" stroke-opacity="0.25" fill="currentColor" fill-opacity="0.06"/>
              <rect x="4" y="5"  width="36" height="2" rx="1" fill="currentColor" fill-opacity="0.3"/>
              <rect x="4" y="10" width="28" height="2" rx="1" fill="currentColor" fill-opacity="0.18"/>
              <rect x="4" y="15" width="32" height="2" rx="1" fill="currentColor" fill-opacity="0.18"/>
              <rect x="4" y="26" width="50" height="2" rx="1" fill="currentColor" fill-opacity="0.3"/>
              <rect x="4" y="32" width="40" height="2" rx="1" fill="currentColor" fill-opacity="0.18"/>
            </svg>
            <span>Stacked</span>
          </button>

        </div>
      </div>

    </div>
  </div>
</div>
