<div class="tbar">
  <div class="tbar__bc">
    <span>report-app</span>
    <span class="tbar__bc-sep">/</span>
    <b><%= typeof pageLabel !== 'undefined' ? pageLabel : '' %></b>
  </div>
  <div class="tbar__r">
    <span class="tbar-lbl">theme</span>
    <div class="tdot" data-theme-target="carbon"   style="background:#4f8ef7" title="Carbon"></div>
    <div class="tdot" data-theme-target="terminal" style="background:#34d058" title="Terminal"></div>
    <div class="tdot" data-theme-target="ember"    style="background:#f0a030" title="Ember"></div>
    <div class="tbar-sep"></div>
    <div class="tdot" data-theme-target="light"    style="background:#2563eb" title="Light"></div>
    <div class="tdot" data-theme-target="frost"    style="background:#6366f1" title="Frost"></div>
    <div class="tdot" data-theme-target="warm"     style="background:#c2770a" title="Warm"></div>
    <div class="tbar-sep"></div>
    <button class="tbar-settings-btn" id="settingsBtn" title="Settings">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3"/>
        <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
      </svg>
    </button>
    <% if (typeof currentUser !== 'undefined' && currentUser) { %>
    <div style="width:1px;height:14px;background:var(--sb-border);margin:0 4px;flex-shrink:0"></div>
    <div style="width:26px;height:26px;border-radius:50%;background:rgba(255,255,255,0.06);border:1px solid var(--accent);display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:10px;font-weight:700;color:var(--accent)">
      <%= (currentUser.name || currentUser.email || '?').charAt(0).toUpperCase() %>
    </div>
    <% } %>
  </div>
</div>

<!-- Settings Modal -->
<div class="rmodal-backdrop" id="settingsBackdrop" hidden>
  <div class="rmodal settings-modal">
    <div class="rmodal__head">
      <span class="rmodal__title">Settings</span>
      <button class="rmodal__close" id="settingsClose" aria-label="Close settings">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="rmodal__body">

      <!-- Audit Card Layout -->
      <div class="settings-section">
        <div class="settings-section__label">Audit card style</div>
        <div class="settings-section__hint">Choose how locations are displayed during an empty-bin audit (mobile)</div>
        <div class="settings-option-list">

          <button class="settings-option" data-setting="audit-layout" data-value="A">
            <div class="settings-option__text">
              <div class="settings-option__name">A — Context-first</div>
              <div class="settings-option__sub">Location in topbar, data leads, actions pinned at the bottom</div>
            </div>
            <div class="settings-option__radio"><div class="settings-option__dot"></div></div>
          </button>

          <button class="settings-option" data-setting="audit-layout" data-value="B">
            <div class="settings-option__text">
              <div class="settings-option__name">B — Decision-first</div>
              <div class="settings-option__sub">Location centred large, actions appear before context data</div>
            </div>
            <div class="settings-option__radio"><div class="settings-option__dot"></div></div>
          </button>

          <button class="settings-option" data-setting="audit-layout" data-value="C">
            <div class="settings-option__text">
              <div class="settings-option__name">C — Warehouse-visible</div>
              <div class="settings-option__sub">Giant 52px location code readable at arm's length, progress dots in topbar</div>
            </div>
            <div class="settings-option__radio"><div class="settings-option__dot"></div></div>
          </button>

          <button class="settings-option" data-setting="audit-layout" data-value="D">
            <div class="settings-option__text">
              <div class="settings-option__name">D — Two-zone split</div>
              <div class="settings-option__sub">Context scrolls independently, decision zone permanently pinned to bottom</div>
            </div>
            <div class="settings-option__radio"><div class="settings-option__dot"></div></div>
          </button>

        </div>
      </div>

      <!-- Nav Layout -->
      <div class="settings-section">
        <div class="settings-section__label">Navigation bar</div>
        <div class="settings-section__hint">Choose which items appear in the mobile bottom navigation</div>
        <div class="settings-option-list">

          <button class="settings-option" data-setting="nav-layout" data-value="A">
            <div class="settings-option__text">
              <div class="settings-option__name">A — Full (6 items)</div>
              <div class="settings-option__sub">All main pages visible: Heatmap, Orders, Bins, Reports, β Reports, Admin</div>
            </div>
            <div class="settings-option__radio"><div class="settings-option__dot"></div></div>
          </button>

          <button class="settings-option" data-setting="nav-layout" data-value="B">
            <div class="settings-option__text">
              <div class="settings-option__name">B — Balanced (5 items)</div>
              <div class="settings-option__sub">Heatmap, Orders, Bins, Reports, Admin — β Reports and SQL tucked away</div>
            </div>
            <div class="settings-option__radio"><div class="settings-option__dot"></div></div>
          </button>

          <button class="settings-option" data-setting="nav-layout" data-value="C">
            <div class="settings-option__text">
              <div class="settings-option__name">C — Minimal (4 items)</div>
              <div class="settings-option__sub">Bins, Reports, Heatmap, Admin — maximum screen real estate</div>
            </div>
            <div class="settings-option__radio"><div class="settings-option__dot"></div></div>
          </button>

          <button class="settings-option" data-setting="nav-layout" data-value="D">
            <div class="settings-option__text">
              <div class="settings-option__name">D — Icon-only slim</div>
              <div class="settings-option__sub">5 items, no labels — reclaims vertical height for content</div>
            </div>
            <div class="settings-option__radio"><div class="settings-option__dot"></div></div>
          </button>

        </div>
      </div>

    </div>
  </div>
</div>
