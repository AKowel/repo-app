<!DOCTYPE html>
<html lang="en" data-theme="carbon">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' — ' : '' %><%= appName %></title>

  <!-- Apply saved theme before first paint to prevent flash -->
  <script>
    (function () {
      var VALID = ['carbon','terminal','ember','light','frost','warm'];
      var LEGACY = { dark: 'carbon', light: 'light', warm: 'warm' };
      var t = localStorage.getItem('repo-theme') || 'carbon';
      if (LEGACY[t] && !VALID.includes(t)) t = LEGACY[t];
      if (!VALID.includes(t)) t = 'carbon';
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <link rel="stylesheet" href="/css/tokens.css" />
  <link rel="stylesheet" href="/css/reset.css" />
  <link rel="stylesheet" href="/css/layout.css" />
  <link rel="stylesheet" href="/css/components.css" />
  <link rel="stylesheet" href="/css/heatmap.css" />
  <% if (typeof extraCss !== 'undefined') { %><link rel="stylesheet" href="<%= extraCss %>" /><% } %>
</head>
<body>
