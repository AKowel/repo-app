<header class="app-header">
  <!-- Brand -->
  <a href="/" class="app-header__brand">
    <div class="app-header__logo">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
      </svg>
    </div>
    <span class="app-header__name"><%= appName %></span>
  </a>

  <!-- Nav -->
  <nav class="app-header__nav">
    <a href="/heatmap"
       class="app-header__nav-link<%= typeof activePage !== 'undefined' && activePage === 'heatmap' ? ' app-header__nav-link--active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
        <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
      </svg>
      Heatmap
    </a>
    <a href="/order-lines"
       class="app-header__nav-link<%= typeof activePage !== 'undefined' && activePage === 'order-lines' ? ' app-header__nav-link--active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/>
        <rect x="9" y="3" width="6" height="4" rx="1"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/>
      </svg>
      Order Lines
    </a>
    <a href="/admin"
       class="app-header__nav-link<%= typeof activePage !== 'undefined' && activePage === 'admin' ? ' app-header__nav-link--active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/>
      </svg>
      Admin
    </a>
  </nav>

  <!-- Actions -->
  <div class="app-header__actions">
    <!-- Theme switcher -->
    <button class="theme-btn" data-theme-target="light"  title="Light theme"  aria-label="Light theme">☀️</button>
    <button class="theme-btn" data-theme-target="dark"   title="Dark theme"   aria-label="Dark theme">🌙</button>
    <button class="theme-btn" data-theme-target="warm"   title="Warm theme"   aria-label="Warm theme">🌿</button>

    <div class="header-divider"></div>

    <% if (currentUser) { %>
      <div class="header-user">
        <div class="header-user__avatar">
          <%= (currentUser.name || currentUser.email || '?').charAt(0).toUpperCase() %>
        </div>
        <span class="header-user__name"><%= currentUser.name || currentUser.email %></span>
      </div>
      <form method="POST" action="/logout" style="display:contents">
        <button type="submit" class="header-signout">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
          Sign out
        </button>
      </form>
    <% } %>
  </div>
</header>
