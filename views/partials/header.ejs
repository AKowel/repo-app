<aside class="sb">
  <!-- Brand -->
  <div class="sb__brand">
    <div class="sb__logo">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
      </svg>
    </div>
    <div class="sb__name"><%= appName %><span>reporting center</span></div>
  </div>

  <!-- Nav -->
  <nav class="sb__nav">
    <div class="sb__sec">Views</div>

    <a href="/heatmap" class="ni<%= typeof activePage !== 'undefined' && activePage === 'heatmap' ? ' ni--active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
        <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
      </svg>
      Heatmap
    </a>

    <a href="/order-lines" class="ni<%= typeof activePage !== 'undefined' && activePage === 'order-lines' ? ' ni--active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/>
        <line x1="8" y1="18" x2="21" y2="18"/>
        <line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>
      </svg>
      Order Lines
    </a>

    <a href="/empty-bins" class="ni<%= typeof activePage !== 'undefined' && activePage === 'empty-bins' ? ' ni--active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 7h16"/><path d="M6 7v12h12V7"/><path d="M9 11h6"/><path d="M9 15h4"/><path d="M8 7V5h8v2"/>
      </svg>
      Empty Bins
    </a>

    <a href="/reports" class="ni<%= typeof activePage !== 'undefined' && activePage === 'reports' ? ' ni--active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
      </svg>
      Reports
    </a>

    <a href="/beta-reports" class="ni<%= typeof activePage !== 'undefined' && activePage === 'beta-reports' ? ' ni--active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 19V5"/><path d="M4 19h16"/>
        <path d="M8 15l3-3 3 2 5-7"/>
        <circle cx="8" cy="15" r="1"/><circle cx="11" cy="12" r="1"/><circle cx="14" cy="14" r="1"/><circle cx="19" cy="7" r="1"/>
      </svg>
      (Beta) Reports
    </a>

    <a href="/admin" class="ni<%= typeof activePage !== 'undefined' && activePage === 'admin' ? ' ni--active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14"/>
      </svg>
      Admin
    </a>
  </nav>

  <!-- User / sign out -->
  <div class="sb__bot">
    <% if (currentUser) { %>
    <form method="POST" action="/logout" style="display:contents">
      <button type="submit" class="user" title="Sign out">
        <div class="uav"><%= (currentUser.name || currentUser.email || '?').charAt(0).toUpperCase() %></div>
        <div style="flex:1;min-width:0">
          <div class="un"><%= currentUser.name || currentUser.email %></div>
          <div class="ue"><%= currentUser.email %></div>
        </div>
        <svg style="width:14px;height:14px;color:var(--sb-xs);flex-shrink:0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
          <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
      </button>
    </form>
    <% } %>
  </div>
</aside>
